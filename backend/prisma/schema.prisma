generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 1. Định nghĩa Enum cho các quyền
enum Role {
  ADMIN
  MEMBER
}

model User {
  id         Int     @id @default(autoincrement())
  username   String  @unique
  password   String
  telegramId String?

  // 2. Thêm trường role, mặc định khách tạo tài khoản sẽ là MEMBER
  role Role @default(MEMBER)

  // --- THÊM MỚI CHO TÍNH NĂNG /STARTBOT VÀ /STOPBOT ---
  isBotActive Boolean @default(true)

  createdAt DateTime @default(now())
  expiredAt DateTime

  follows Follow[]
}

model Follow {
  id              Int       @id @default(autoincrement())
  keyword         String?
  categoryId      String?
  brandId         String?
  status          String? // ITEM_STATUS_ON_SALE, ITEM_STATUS_SOLD_OUT, ITEM_STATUS_TRADING_OUT
  priceMin        Int?
  priceMax        Int?
  itemConditionId String?
  isActive        Boolean   @default(false)
  lastScannedAt   DateTime?

  userId Int
  user   User @relation(fields: [userId], references: [id])
}
